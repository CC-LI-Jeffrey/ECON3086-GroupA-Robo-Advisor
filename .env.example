# HKBU GenAI API key (see README Step 4)
#
# 1. Copy this file to `.env` in the project root:
#      cp .env.example .env
#    (Windows PowerShell: Copy-Item .env.example .env)
#
# 2. Replace the empty value below with your real key from HKBU GenAI.
#    Do not commit `.env`; only this `.env.example` belongs in git.
#
# Endpoint used by `ai.py`: https://genai.hkbu.edu.hk

HKBU_AI_API_KEY=
